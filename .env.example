# Mock auth + tickets (no backend). Set to false when using a real API.
VITE_USE_MOCK=true

# Backend base URL (no trailing slash). Leave unset in mock mode.
# VITE_API_URL=https://api.example.com

# If your API returns JWT in JSON for local dev only, set true. Production should use HttpOnly cookies.
# VITE_DEV_BEARER_FROM_BODY=false

# Clay OTP login API (optional override; defaults to https://esimgo.clay.in/api/Authentication)
# VITE_CLAY_AUTH_BASE=https://esimgo.clay.in/api/Authentication

# Comma-separated Clay usernames that get admin role in the app after OTP (e.g. ops.lead,admin.user)
# VITE_CLAY_ADMIN_USERNAMES=
